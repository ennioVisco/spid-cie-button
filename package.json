{
  "name": "spid-cie-button",
  "version": "1.0.5",
  "description": "A web component to authenticate with SPID and CIE",
  "keywords": [
    "Button",
    "CIE",
    "SPID",
    "Web Component",
    "authentication"
  ],
  "homepage": "https://github.com/enniovisconti/spid-cie-button#readme",
  "bugs": {
    "url": "https://github.com/enniovisconti/spid-cie-button/issues"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Ennio Visconti",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enniovisconti/spid-cie-button.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/client/index.js",
  "module": "dist/client/index.js",
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server/server.d.ts"
      ],
      "client": [
        "./dist/client/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/entry-server.d.ts",
      "default": "./dist/server/entry-server.js"
    }
  },
  "scripts": {
    "changes": "bunx changelog --exclude chore,build,ci",
    "fmt": "oxfmt .",
    "lint": "oxlint",
    "typecheck": "tsgo --noEmit",
    "dev": "bun run fmt && bun server",
    "build": "bun run build:client && bun run build:server",
    "build:client": "BUILD_TARGET=client vite build",
    "build:server": "BUILD_TARGET=server vite build",
    "preview": "NODE_ENV=production bun server",
    "release": "bun run build && npm publish",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "bun-types": "latest",
    "generate-changelog": "^1.8.0",
    "ofetch": "2.0.0-alpha.3",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rolldown-plugin-dts": "^0.22.1",
    "vite": "^8.0.0-beta.15"
  },
  "peerDependencies": {
    "ofetch": "2.0.0-alpha.3"
  }
}
